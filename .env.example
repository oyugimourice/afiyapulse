# ============================================
# AfiyaPulse Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Neon Postgres Database
# Get from: https://console.neon.tech/
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/afiyapulse?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/afiyapulse?sslmode=require"

# Test Database (for running tests)
TEST_DATABASE_URL="postgresql://test:test@localhost:5432/afiyapulse_test"

# ============================================
# CACHE & SESSION STORAGE
# ============================================
# Redis (Upstash or self-hosted)
# Get from: https://console.upstash.com/
REDIS_URL="redis://default:xxx@xxx.upstash.io:6379"
# If you only have the REST connect credentials from Upstash, use these instead:
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# Test Redis (for running tests)
TEST_REDIS_URL="redis://localhost:6379/1"

# ============================================
# IBM CLOUD SERVICES
# ============================================
# IBM Watson Speech-to-Text
# Get from: https://cloud.ibm.com/catalog/services/speech-to-text
WATSON_STT_API_KEY="your-watson-stt-api-key"
WATSON_STT_URL="https://api.us-south.speech-to-text.watson.cloud.ibm.com"

# IBM Cloud Object Storage (for audio files)
# Get HMAC credentials from: https://cloud.ibm.com/objectstorage
# IMPORTANT: Use HMAC credentials, NOT IAM API key
AWS_ACCESS_KEY_ID="your-cos-hmac-access-key-id"
AWS_SECRET_ACCESS_KEY="your-cos-hmac-secret-access-key"
AWS_S3_BUCKET="afiyapulse-audio"
AWS_REGION="us-east"
AWS_ENDPOINT="https://s3.us-east.cloud-object-storage.appdomain.cloud"

# ============================================
# AI MODEL PROVIDERS
# ============================================
# OpenAI (Primary)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-xxx"
OPENAI_MODEL="gpt-4-turbo-preview"

# Anthropic Claude (Alternative)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-xxx"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# AI Provider Selection (openai or anthropic)
AI_PROVIDER="openai"

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT Configuration
# Generate secure secrets: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Session Configuration
SESSION_SECRET="your-session-secret-min-32-chars-change-in-production"

# Encryption Key for PHI Data (AES-256)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-encryption-key-64-hex-chars-for-aes-256"

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Environment
NODE_ENV="development"

# Server Configuration
PORT="3001"
HOST="0.0.0.0"

# URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"
# For multiple origins: CORS_ORIGIN="http://localhost:3000,https://app.afiyapulse.com"

# ============================================
# RATE LIMITING
# ============================================
# General API Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# Authentication Rate Limiting
AUTH_RATE_LIMIT_WINDOW_MS="60000"
AUTH_RATE_LIMIT_MAX_REQUESTS="5"

# Upload Rate Limiting
UPLOAD_RATE_LIMIT_WINDOW_MS="300000"
UPLOAD_RATE_LIMIT_MAX_REQUESTS="10"

# AI Agent Rate Limiting
AGENT_RATE_LIMIT_WINDOW_MS="60000"
AGENT_RATE_LIMIT_MAX_REQUESTS="20"

# ============================================
# LOGGING & MONITORING
# ============================================
# Log Level (error, warn, info, debug)
LOG_LEVEL="info"

# Enable Request Logging
ENABLE_REQUEST_LOGGING="true"

# Enable Performance Monitoring
ENABLE_PERFORMANCE_MONITORING="true"

# ============================================
# FEATURE FLAGS
# ============================================
# MCP Servers
ENABLE_MCP_SERVERS="true"
ENABLE_DRUG_DATABASE="true"
ENABLE_FHIR_EHR="true"
ENABLE_APPOINTMENTS="true"

# AI Features
ENABLE_AI_AGENTS="true"
ENABLE_REAL_TIME_TRANSCRIPTION="true"

# Security Features
ENABLE_AUDIT_LOGGING="true"
ENABLE_DATA_ENCRYPTION="true"

# ============================================
# CACHE CONFIGURATION
# ============================================
# Cache TTL (in seconds)
CACHE_TTL_SHORT="300"
CACHE_TTL_MEDIUM="1800"
CACHE_TTL_LONG="3600"

# Enable Cache
ENABLE_CACHE="true"

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Maximum file size (in bytes)
MAX_FILE_SIZE="52428800"

# Allowed audio formats
ALLOWED_AUDIO_FORMATS="audio/webm,audio/wav,audio/mp3,audio/mpeg"

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
# WebSocket Configuration
WS_PING_INTERVAL="30000"
WS_PING_TIMEOUT="5000"

# ============================================
# HIPAA COMPLIANCE
# ============================================
# Audit Log Retention (in days)
AUDIT_LOG_RETENTION_DAYS="2555"

# Enable PHI Encryption
ENABLE_PHI_ENCRYPTION="true"

# Enable Access Logging
ENABLE_ACCESS_LOGGING="true"

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Enable Debug Mode
DEBUG="false"

# Enable Hot Reload
ENABLE_HOT_RELOAD="true"

# Seed Database on Start
SEED_DATABASE="false"

# ============================================
# PRODUCTION ONLY
# ============================================
# Force HTTPS
FORCE_HTTPS="false"

# Enable Compression
ENABLE_COMPRESSION="true"

# Trust Proxy (for load balancers)
TRUST_PROXY="false"

# IP Whitelist (comma-separated)
# IP_WHITELIST="1.2.3.4,5.6.7.8"

# ============================================
# OPTIONAL: EXTERNAL INTEGRATIONS
# ============================================
# Sentry Error Tracking
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Slack Notifications
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx"

# Email Service (SendGrid, AWS SES, etc.)
# EMAIL_SERVICE="sendgrid"
# EMAIL_API_KEY="your-email-api-key"
# EMAIL_FROM="noreply@afiyapulse.com"

# ============================================
# NOTES
# ============================================
# 1. Generate secure secrets using: openssl rand -base64 32
# 2. Never commit .env file to version control
# 3. Use different values for development, staging, and production
# 4. Rotate secrets regularly (every 90 days recommended)
# 5. Store production secrets in secure vault (IBM Secrets Manager, AWS Secrets Manager, etc.)